  },
  "homepage": "https://zelquent.com",
  "bugs": {
    "url": "https://github.com/zelquent-tech/website/issues"
  },
  "keywords": [
    "Web development company",
    "UI UX design agency",
    "Accessibility solutions",
    "Full stack web development",
    "AI integration services",
    "Backend API development",
    "DevOps consulting",
    "Web hosting services",
    "Zelquent Tech",
    "Professional web development",
    "Custom web applications",
    "Enterprise software development",
    "React development company",
    "Node.js backend services",
    "Cloud hosting solutions",
    "WCAG compliance services",
    "AI powered applications",
    "REST API development",
    "GraphQL API design",
    "AWS cloud services",
    "Digital transformation agency",
    "Startup tech solutions",
    "Modern web design",
    "Responsive web development",
    "Technical consulting services"
  ],
  "scripts": {
    "dev": "vite --host --port 3000",
    "build": "vite build",
    "preview": "vite preview --host --port 3000",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css,scss,md,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css,scss,md,json}\"",
    "predeploy": "npm run build",
    "analyze": "vite build --mode analyze",
    "preview:build": "vite preview --host",
    "clean": "rm -rf dist node_modules/.cache"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@hookform/resolvers": "^3.10.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.0",
    "lucide-react": "^0.400.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-intersection-observer": "^9.13.1",
    "react-lazy-load-image-component": "^1.6.0",
    "react-router-dom": "^7.13.1",
    "swiper": "^11.2.5",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@tailwindcss/vite": "^4.0.15",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.23.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "rollup-plugin-visualizer": "^5.14.0",
    "tailwindcss": "^3.4.17",
    "vite": "^6.2.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^0.21.2"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all",
      "not ie 11",
      "maintained node versions"
    ],
    "development": [
      "last 2 chrome versions",
      "last 2 firefox versions",
      "last 2 safari versions",
      "last 2 edge versions"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "yarn": "NOT RECOMMENDED - use npm"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss,md,json}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "endOfLine": "auto",
    "plugins": [
      "prettier-plugin-tailwindcss"
    ]
  },
  "volta": {
    "node": "20.18.3",
    "npm": "10.8.2"
  }
}
